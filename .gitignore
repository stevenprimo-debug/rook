# Vector indices — rebuilt by librarian weekly sweep, not source-controlled
agents/*/memory/.vector-index/
**/.vector-index/

# SQLite databases — customer data, never committed
**/*.db
**/*.db-journal
**/*.db-shm
**/*.db-wal

# Customer-personal config (generated by onboarding)
~/.claude/
.claude/local.settings.json

# Secrets — never commit
**/.env
**/.env.*
!**/.env.example
!**/.env.template
**/secrets.json
**/credentials.json
**/*.pem
**/*.key
**/*api-key*
**/*api_key*

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Node
node_modules/
package-lock.json
yarn.lock

# Logs
*.log
agents/librarian/librarian-log.md
_FROM_CLAUDE/

# Temp / scratch
_tmp/
_scratch/
*.tmp
*.bak

# OS-specific compiled binaries inside vendored skills (keep source, not binaries)
.claude/skills/core/obsidian-cli/notesmd.exe
.claude/skills/core/obsidian-cli/**/*.exe

# Vendored sub-repo gits (these are upstream repos; don't track their internal git state)
.claude/skills/core/obsidian-cli/.git/
.claude/skills/registry/claude-design-skill/.git/
.claude/skills/registry/design-for-ai/.git/
.claude/skills/registry/freecad-mcp/.git/
.claude/skills/registry/gsap-skills/.git/
.claude/skills/registry/ui-ux-pro-max-skill/.git/

# Markitdown test fixtures (third-party, large)
.claude/skills/core/markitdown/src/packages/markitdown/tests/test_files/
.claude/skills/core/markitdown/src/packages/markitdown-sample-plugin/tests/test_files/
.claude/skills/registry/autocad-mcp/
.mcp.json
vault-agents/
_archive/

# Graphify output — operator-local graph cache containing absolute filesystem paths.
# Each customer's librarian regenerates this on weekly sweep against THEIR vault.
.claude/reference/graphify-out/
agents/*/graphify-out/

# Root-level graphify cache (operator-local; rebuilt by librarian)
graphify-out-memory/

# Operator-local Claude Code settings (never ships)
.claude/settings.local.json

# Operator-personal skills — never ships in cohort zip / public clone
.claude/skills/_personal/

# Operator-local agent state (per-operator compounding history; never ships in cohort zip)
# Per .env FILES_OPERATOR_LOCAL — agent memory is per-operator.
agents/*/memory/
# Operator-personal dispatch briefs (chief-of-staff routes; cohort starts empty)
agents/chief-of-staff/assignments/
# Librarian weekly digests (regenerated per-operator on weekly sweep)
agents/librarian/digests/
# Explicit per-file overrides — these were tracked BEFORE agents/*/memory/ rule;
# untracked 2026-05-23 per github-expert bench verdict (Option A) to honor the
# gitignore contract without rewriting history.
agents/chief-of-staff/memory/dispatch_log.md
agents/chief-of-staff/memory/idea_log.md

# Operator-only master agent skill template — never ships in cohort zip / public clone.
# The 7-section ROOK Master Skill scaffold is proprietary IP; operators receive it
# via OPERATOR vault sync, not via marketplace clone. Untracked 2026-05-23 per
# github-expert Option A precedent.
agents/_template/
# Root-level graphify cache mirror (operator-local; rebuilt by librarian)
graphify-out/

# WebFetch allowlist gate runtime log — append-only, per-machine
.claude/connectors/_gate.log
