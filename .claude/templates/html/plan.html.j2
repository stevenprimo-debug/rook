<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} - {{ brand_name }}</title>
<style>
  :root { --primary: {{ primary_color }}; --accent: {{ accent }}; --body-font: {{ body_font }}; --heading-font: {{ heading_font }}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--body-font); background: #fff; color: #0F172A; line-height: 1.6; padding: 2rem; max-width: 960px; margin: 0 auto; }
  header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 1.5rem; border-bottom: 3px solid var(--primary); margin-bottom: 2rem; }
  .brand { font-family: var(--heading-font); font-weight: 700; color: var(--primary); }
  h1 { font-family: var(--heading-font); font-size: 2rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem; }
  h2 { font-family: var(--heading-font); font-size: 1.2rem; font-weight: 600; color: var(--primary); margin: 2rem 0 0.75rem; padding-left: 0.75rem; border-left: 3px solid var(--accent); }
  h3 { font-size: 1rem; font-weight: 600; color: #334155; margin: 1rem 0 0.5rem; }
  p { margin-bottom: 0.75rem; }
  .phase-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin: 1rem 0; }
  .phase-card { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 6px; padding: 1rem; }
  .phase-num { font-size: 0.75rem; font-weight: 700; color: var(--accent); text-transform: uppercase; }
  .phase-title { font-weight: 600; color: var(--primary); margin: 0.25rem 0; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.875rem; }
  th { background: var(--primary); color: #fff; padding: 0.5rem 0.75rem; text-align: left; }
  td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #E2E8F0; vertical-align: top; }
  ul { margin: 0.5rem 0 0.75rem 1.5rem; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #E2E8F0; font-size: 0.75rem; color: #94A3B8; text-align: center; }
</style>
</head>
<body>
<header>
  <span class="brand">{{ brand_name }}</span>
  <span style="font-size:0.8rem;color:#64748B;">{{ date }}</span>
</header>
<h1>{{ title }}</h1>
{% if summary %}<p style="font-size:1.05rem;color:#475569;margin-bottom:2rem;">{{ summary }}</p>{% endif %}
{{ body }}
<footer>{{ brand_name }} Plan - {{ date }}</footer>
</body>
</html>