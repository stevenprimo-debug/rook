<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} - {{ brand_name }}</title>
<style>
  :root { --primary: {{ primary_color }}; --accent: {{ accent }}; --body-font: {{ body_font }}; --heading-font: {{ heading_font }}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--body-font); background: #fff; color: #0F172A; line-height: 1.65; max-width: 900px; margin: 0 auto; padding: 2rem; }
  .cover { background: var(--primary); color: #fff; border-radius: 8px; padding: 3rem 2.5rem; margin-bottom: 3rem; }
  .cover .brand { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; opacity: 0.7; text-transform: uppercase; margin-bottom: 1.5rem; }
  .cover h1 { font-family: var(--heading-font); font-size: 2.2rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.2; }
  .cover .cover-meta { font-size: 0.875rem; opacity: 0.75; margin-top: 1.5rem; }
  h2 { font-family: var(--heading-font); font-size: 1.2rem; font-weight: 700; color: var(--primary); margin: 2rem 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E2E8F0; }
  h3 { font-size: 1rem; font-weight: 600; color: #334155; margin: 1.25rem 0 0.5rem; }
  p { margin-bottom: 0.85rem; }
  ul, ol { margin: 0.5rem 0 1rem 1.5rem; }
  li { margin-bottom: 0.3rem; }
  .value-row { display: flex; justify-content: space-between; align-items: baseline; padding: 0.6rem 0; border-bottom: 1px solid #F1F5F9; }
  .value-row .label { color: #475569; }
  .value-row .amount { font-weight: 700; color: var(--primary); }
  .sig-block { border: 1px solid #E2E8F0; border-radius: 6px; padding: 1.5rem; margin: 1rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .sig-line { border-bottom: 1px solid #CBD5E1; padding-bottom: 0.5rem; min-height: 2.5rem; }
  .sig-label { font-size: 0.75rem; color: #64748B; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #E2E8F0; font-size: 0.75rem; color: #94A3B8; display: flex; justify-content: space-between; }
</style>
</head>
<body>
<div class="cover">
  <div class="brand">{{ brand_name }}</div>
  <h1>{{ title }}</h1>
  {% if subtitle %}<p style="opacity:0.85;">{{ subtitle }}</p>{% endif %}
  <div class="cover-meta">Prepared for {{ client }} - {{ date }}</div>
</div>
{{ body }}
<footer><span>{{ brand_name }} - Confidential</span><span>{{ date }}</span></footer>
</body>
</html>