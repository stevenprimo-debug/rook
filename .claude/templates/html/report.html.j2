<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} - {{ brand_name }}</title>
<style>
  :root { --primary: {{ primary_color }}; --accent: {{ accent }}; --body-font: {{ body_font }}; --heading-font: {{ heading_font }}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--body-font); background: #fff; color: #0F172A; line-height: 1.6; max-width: 920px; margin: 0 auto; padding: 2rem; }
  header { border-bottom: 3px solid var(--primary); padding-bottom: 1.5rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
  .brand-mark { font-family: var(--heading-font); font-weight: 700; color: var(--primary); }
  h1 { font-family: var(--heading-font); font-size: 1.9rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem; }
  .exec-summary { background: #F8FAFC; border-left: 4px solid var(--accent); padding: 1.25rem 1.5rem; margin: 1.5rem 0 2rem; }
  .exec-summary .exec-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); margin-bottom: 0.5rem; }
  h2 { font-family: var(--heading-font); font-size: 1.15rem; font-weight: 600; color: var(--primary); margin: 2rem 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid #E2E8F0; }
  h3 { font-size: 1rem; font-weight: 600; color: #334155; margin: 1.25rem 0 0.5rem; }
  p { margin-bottom: 0.85rem; }
  ul, ol { margin: 0.5rem 0 1rem 1.5rem; }
  li { margin-bottom: 0.3rem; }
  table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.875rem; }
  th { background: var(--primary); color: #fff; padding: 0.5rem 0.75rem; text-align: left; }
  td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #E2E8F0; }
  .appendix { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px dashed #CBD5E1; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #E2E8F0; font-size: 0.75rem; color: #94A3B8; display: flex; justify-content: space-between; }
</style>
</head>
<body>
<header>
  <span class="brand-mark">{{ brand_name }}</span>
  <div style="font-size:0.8rem;color:#64748B;text-align:right;"><strong>{{ title }}</strong><br>{{ date }}</div>
</header>
<h1>{{ title }}</h1>
{% if exec_summary %}
<div class="exec-summary">
  <div class="exec-label">Executive Summary</div>
  {{ exec_summary }}
</div>
{% endif %}
{{ body }}
{% if appendix %}
<div class="appendix">
  <h2>Appendix</h2>
  {{ appendix }}
</div>
{% endif %}
<footer><span>{{ brand_name }}</span><span>{{ date }}</span></footer>
</body>
</html>